---
interface Props {
	role: 'member' | 'staff' | 'admin';
}

const { role } = Astro.props;

const navItems = {
	member: [
		{ name: 'Dashboard',           href: '/member/dashboard' },
		{ name: 'Subscription Plans',  href: '/member/subscription-plans' },
		{ name: 'QR Code',             href: '/member/qr-code' },
		{ name: 'Profile',             href: '/member/profile' },
	],
	staff: [
		{ name: 'Dashboard',           href: '/staff/dashboard' },
		{ name: 'QR Verification',     href: '/staff/qr-verify' },
		{ name: 'Member Search',       href: '/staff/member-search' },
		{ name: 'Renew Subscription',  href: '/staff/renew-subscription' },
	],
	admin: [
		{ name: 'Dashboard',           href: '/admin/dashboard' },
		{ name: 'Members',             href: '/admin/manage-members' },
		{ name: 'Staff',               href: '/admin/manage-staff' },
		{ name: 'Subscriptions',       href: '/admin/subscriptions' },
		{ name: 'Logs',                href: '/admin/logs' },
	],
};

const items = navItems[role];
---

<nav class="navbar">
	<div class="nav-logo">
		<a href="/">
			<img src="/logo.svg" alt="Sahati Gym" transition:persist />
		</a>
	</div>

	<!-- Hamburger toggle (mobile) -->
	<button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
		<span></span><span></span><span></span>
	</button>

	<div class="nav-right" id="nav-right">
		<ul class="nav-links">
			{items.map(item => (
				<li><a href={item.href}>{item.name}</a></li>
			))}
		</ul>
		<form action="/api/auth/logout" method="POST" id="logout-form">
			<button type="submit" class="logout-btn">Logout</button>
		</form>
	</div>
</nav>

<script>
	// Logout loading state
	const logoutForm = document.getElementById('logout-form') as HTMLFormElement;
	logoutForm?.addEventListener('submit', () => {
		const btn = logoutForm.querySelector('button');
		btn?.classList.add('loading');
	});

	// Active link highlight
	const currentPath = window.location.pathname;
	document.querySelectorAll('.nav-links a').forEach(link => {
		const href = link.getAttribute('href') || '';
		if (currentPath === href || (href !== '/' && currentPath.startsWith(href))) {
			link.classList.add('active');
		}
	});

	// Mobile hamburger
	const hamburger = document.getElementById('hamburger');
	const navRight  = document.getElementById('nav-right');
	hamburger?.addEventListener('click', () => {
		const open = navRight!.classList.toggle('open');
		hamburger.setAttribute('aria-expanded', String(open));
		hamburger.classList.toggle('is-open', open);
	});
</script>

<style>
	.navbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.85rem 2rem;
		background: rgba(9, 46, 62, 0.72);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255,255,255,0.08);
		position: sticky;
		top: 0;
		z-index: 500;
	}

	.nav-logo {
		height: 38px;
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.nav-logo a {
		display: flex;
		height: 100%;
	}

	.nav-logo img {
		height: 100%;
		width: auto;
		object-fit: contain;
		display: block;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.nav-links {
		display: flex;
		list-style: none;
		gap: 0.25rem;
		margin: 0;
		padding: 0;
		align-items: center;
	}

	.nav-links a {
		text-decoration: none;
		font-size: 0.875rem;
		font-weight: 500;
		color: rgba(255,255,255,0.78);
		padding: 0.4rem 0.75rem;
		border-radius: 6px;
		transition: color 0.15s, background 0.15s;
		white-space: nowrap;
	}

	.nav-links a:hover {
		color: #fff;
		background: rgba(255,255,255,0.08);
	}

	.nav-links a.active {
		color: #fff;
		background: rgba(255,255,255,0.12);
		font-weight: 600;
	}

	.logout-btn {
		background: transparent;
		border: 1.5px solid rgba(211,217,212,0.55);
		color: #d3d9d4;
		padding: 0.42rem 1rem;
		border-radius: 6px;
		cursor: pointer;
		font-size: 0.85rem;
		font-weight: 600;
		font-family: 'Inter', system-ui, sans-serif;
		transition: background 0.15s, color 0.15s;
		position: relative;
		white-space: nowrap;
	}

	.logout-btn:hover {
		background: #d3d9d4;
		color: #0d3a4d;
	}

	/* Hamburger */
	.hamburger {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.4rem;
		border-radius: 6px;
	}

	.hamburger span {
		display: block;
		width: 22px;
		height: 2px;
		background: #fff;
		border-radius: 2px;
		transition: transform 0.2s, opacity 0.2s;
	}

	.hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
	.hamburger.is-open span:nth-child(2) { opacity: 0; }
	.hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

	/* Mobile */
	@media (max-width: 768px) {
		.hamburger { display: flex; }

		.nav-right {
			display: none;
			position: fixed;
			top: 60px;
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			background: rgba(9, 46, 62, 0.98);
			border-bottom: 1px solid rgba(255,255,255,0.08);
			padding: 1rem;
			z-index: 499;
		}

		.nav-right.open { display: flex; }

		.nav-links {
			flex-direction: column;
			align-items: stretch;
			gap: 0;
		}

		.nav-links li { width: 100%; }

		.nav-links a {
			display: block;
			padding: 0.7rem 1rem;
			font-size: 0.95rem;
		}

		.logout-btn {
			width: 100%;
			margin-top: 0.5rem;
			padding: 0.65rem 1rem;
			text-align: center;
		}
	}
</style>
