---
import StaffLayout from '../../layouts/StaffLayout.astro';
---

<StaffLayout title="Renew Subscription | Sahati Gym">
	<section class="renew-container">
		<div class="page-header">
			<h1>Renew Subscription</h1>
			<p>Search for a member and update their plan and end date.</p>
		</div>

		<div class="card search-card">
			<div class="search-wrapper">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				<input type="text" id="member-search" placeholder="Search by name, email, or phone..." />
			</div>
		</div>

		<div class="card table-card">
			<div class="table-scroll">
				<table class="member-table">
					<thead>
						<tr>
							<th>Member</th>
							<th>Current Plan</th>
							<th>Status</th>
							<th>Expiry</th>
							<th>Action</th>
						</tr>
					</thead>
					<tbody id="member-list-body">
						<tr>
							<td colspan="5" class="empty-row">Loading members…</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<!-- Renewal Modal -->
	<div id="renewal-modal" class="modal hidden">
		<div class="modal-content">
			<div class="modal-header">
				<h2>Renew Subscription</h2>
			</div>
			<div id="selected-member-info" class="member-info-box"></div>

			<div class="form-row">
				<div class="form-group">
					<label for="plan-select">Plan</label>
					<select id="plan-select">
						<option value="Lite">Lite – 1 Month</option>
						<option value="Plus">Plus – 3 Months</option>
						<option value="Pro">Pro – 6 Months</option>
						<option value="Elite">Elite – 1 Year</option>
					</select>
				</div>
				<div class="form-group">
					<label for="status-select">Status</label>
					<select id="status-select">
						<option value="active">Active</option>
						<option value="expired">Inactive/Expired</option>
					</select>
				</div>
			</div>
			<div class="form-group">
				<label for="end-date">New End Date</label>
				<input type="date" id="end-date" required />
			</div>

			<div class="modal-actions">
				<button id="cancel-btn" class="btn secondary">Cancel</button>
				<button id="renew-btn" class="btn primary">Confirm Renewal</button>
			</div>
		</div>
	</div>
</StaffLayout>

<script>
	function init() {
		const searchInput = document.getElementById('member-search') as HTMLInputElement;
		const listBody    = document.getElementById('member-list-body');
		const modal       = document.getElementById('renewal-modal');
		const selectedInfo= document.getElementById('selected-member-info');
		const cancelBtn   = document.getElementById('cancel-btn');
		const renewBtn    = document.getElementById('renew-btn');
		const planSelect  = document.getElementById('plan-select') as HTMLSelectElement;
		const statusSelect= document.getElementById('status-select') as HTMLSelectElement;
		const endDateInput= document.getElementById('end-date')   as HTMLInputElement;

		let members: any[] = [];
		let selectedMemberId = '';

		async function loadMembers(query = '') {
			try {
				const res = await fetch(`/api/staff/search-member?q=${encodeURIComponent(query)}`);
				members = await res.json();
				renderList();
			} catch {
				window.showToast('Failed to load members.', 'error');
			}
		}

		function formatDate(date: string | Date) {
			return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
		}

		function statusBadge(sub: any) {
			if (!sub) return '<span class="badge badge-warning">No Sub</span>';
			const today = new Date();
			const end   = new Date(sub.end_date);
			const isExpired = end < today || sub.status?.toLowerCase() === 'expired';
			return !isExpired
				? '<span class="badge badge-success">Active</span>'
				: '<span class="badge badge-danger">Expired</span>';
		}

		function calculateExpiryDate(plan: string) {
			const d = new Date();
			const p = plan.toLowerCase();
			if (p === 'lite')  d.setMonth(d.getMonth() + 1);
			else if (p === 'plus')  d.setMonth(d.getMonth() + 3);
			else if (p === 'pro')   d.setMonth(d.getMonth() + 6);
			else if (p === 'elite') d.setFullYear(d.getFullYear() + 1);
			else d.setMonth(d.getMonth() + 1);
			return d.toISOString().split('T')[0];
		}

		function renderList() {
			if (!listBody) return;
			if (!members.length) {
				listBody.innerHTML = '<tr><td colspan="5" class="empty-row">No members found.</td></tr>';
				return;
			}
			listBody.innerHTML = members.map(m => {
				const sub    = m.subscriptions?.[0];
				const expiry = sub ? formatDate(sub.end_date) : '—';
				const plan   = sub?.plan ? (sub.plan.charAt(0).toUpperCase() + sub.plan.slice(1)) : '—';
				return `
					<tr>
						<td>
							<div class="member-cell">
								<strong>${m.name}</strong>
								<span class="sub-text">${m.email}</span>
							</div>
						</td>
						<td>${plan}</td>
						<td>${statusBadge(sub)}</td>
						<td>${expiry}</td>
						<td>
							<button class="btn primary sm-btn select-btn" data-id="${m.id}">Select</button>
						</td>
					</tr>
				`;
			}).join('');

			listBody.querySelectorAll('.select-btn').forEach(btn => {
				btn.addEventListener('click', e => {
					const id = (e.currentTarget as HTMLElement).dataset.id!;
					openModal(id);
				});
			});
		}

		function openModal(id: string) {
			const m = members.find(x => x.id === id);
			if (!m) return;
			selectedMemberId = m.id;
			const sub = m.subscriptions?.[0];

			if (selectedInfo) {
				selectedInfo.innerHTML = `
					<div class="info-row"><span class="info-label">Member</span><span>${m.name}</span></div>
					<div class="info-row"><span class="info-label">Email</span><span>${m.email}</span></div>
					<div class="info-row"><span class="info-label">Current Plan</span><span>${sub?.plan ? (sub.plan.charAt(0).toUpperCase() + sub.plan.slice(1)) : '—'}</span></div>
					<div class="info-row"><span class="info-label">Current Expiry</span><span>${sub ? formatDate(sub.end_date) : '—'}</span></div>
				`;
			}

			if (sub?.plan && planSelect) {
				const planVal = sub.plan.charAt(0).toUpperCase() + sub.plan.slice(1);
				if ([...planSelect.options].some(o => o.value === planVal)) planSelect.value = planVal;
			}
			if (sub?.status && statusSelect) {
				const statusVal = sub.status.toLowerCase();
				if ([...statusSelect.options].some(o => o.value === statusVal)) {
					statusSelect.value = statusVal;
				}
			} else if (statusSelect) {
				statusSelect.value = 'active';
			}

			if (endDateInput && planSelect) {
				endDateInput.value = calculateExpiryDate(planSelect.value);
			}
			modal?.classList.remove('hidden');
		}

		planSelect?.addEventListener('change', () => {
			if (endDateInput) endDateInput.value = calculateExpiryDate(planSelect.value);
		});

		cancelBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

		renewBtn?.addEventListener('click', async () => {
			const plan    = planSelect?.value || 'Lite';
			const status  = statusSelect?.value || 'active';
			const endDate = endDateInput?.value;
			if (!endDate) { window.showToast('Please select an end date.', 'error'); return; }

			renewBtn.classList.add('loading');
			try {
				const res = await fetch('/api/staff/renew-subscription', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ memberId: selectedMemberId, plan, endDate, status })
				});
				const result = await res.json();
				if (result.success) {
					modal?.classList.add('hidden');
					window.showToast('✓ Subscription renewed and QR code updated!', 'success');
					loadMembers(searchInput?.value || '');
				} else {
					window.showToast(result.error || 'Renewal failed.', 'error');
				}
			} catch {
				window.showToast('Network error. Please try again.', 'error');
			} finally {
				renewBtn.classList.remove('loading');
			}
		});

		let debounceTimer: ReturnType<typeof setTimeout>;
		searchInput?.addEventListener('input', e => {
			clearTimeout(debounceTimer);
			debounceTimer = setTimeout(() => {
				loadMembers((e.target as HTMLInputElement).value);
			}, 300);
		});

		loadMembers();
	}

	document.addEventListener('astro:page-load', init);
</script>

<style>
	.renew-container {
		max-width: 960px;
		margin: 0 auto;
	}

	.page-header {
		margin-bottom: 2rem;
	}

	.page-header h1 {
		font-size: 1.75rem;
		margin-bottom: 0.3rem;
	}

	.page-header p {
		color: var(--color-text-muted);
		margin: 0;
	}

	/* Search */
	.search-card { padding: 1.25rem 1.5rem; }

	.search-wrapper {
		position: relative;
	}

	.search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--color-text-subtle);
		pointer-events: none;
	}

	.search-wrapper input {
		padding-left: 2.75rem;
	}

	/* Table */
	.table-card { padding: 0; overflow: hidden; }

	.table-scroll { overflow-x: auto; }

	.member-table { min-width: 600px; }

	.member-cell {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.sub-text {
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	.empty-row {
		text-align: center;
		padding: 3rem !important;
		color: var(--color-text-subtle);
	}

	.sm-btn {
		padding: 0.45rem 1rem !important;
		font-size: 0.82rem !important;
	}

	/* Modal member info box */
	.member-info-box {
		background: rgba(0,0,0,0.18);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 1rem 1.25rem;
		margin-bottom: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.info-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.9rem;
	}

	.info-label {
		color: var(--color-text-muted);
		font-size: 0.82rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
</style>
