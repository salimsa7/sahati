---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/admin/login');

const { data: admin } = await supabase
	.from('admins')
	.select('*')
	.eq('id', user.id)
	.single();

const adminName = admin?.name || 'Administrator';
---

<AdminLayout title="Admin Dashboard | Sahati Gym">
	<section class="welcome">
		<h1>Welcome, {adminName}</h1>
		<p>System-wide management and monitoring.</p>
	</section>

	<section class="admin-grid">
		<a href="/admin/manage-members" class="admin-card">
			<div class="icon">👥</div>
			<h3>Manage Members</h3>
			<p>Add, edit, or remove member accounts.</p>
		</a>

		<a href="/admin/manage-staff" class="admin-card">
			<div class="icon">👔</div>
			<h3>Manage Staff</h3>
			<p>Control gym staff access and profiles.</p>
		</a>

		<a href="/admin/subscriptions" class="admin-card">
			<div class="icon">📋</div>
			<h3>Subscriptions</h3>
			<p>Monitor and override member subscriptions.</p>
		</a>

		<a href="/admin/logs" class="admin-card">
			<div class="icon">📜</div>
			<h3>Access Logs</h3>
			<p>Review gym entry and exit history.</p>
		</a>
	</section>
</AdminLayout>

<style>
	.welcome {
		margin-bottom: 2.5rem;
		padding-bottom: 1.75rem;
		border-bottom: 1px solid rgba(255,255,255,0.08);
	}

	h1 {
		font-size: 2rem;
		margin-bottom: 0.4rem;
	}

	.welcome p {
		color: rgba(255,255,255,0.6);
		font-size: 0.95rem;
	}

	.admin-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.25rem;
	}

	.admin-card {
		background: rgba(255, 255, 255, 0.055);
		padding: 2rem 1.75rem;
		border-radius: 14px;
		border: 1px solid rgba(255, 255, 255, 0.10);
		text-align: center;
		text-decoration: none;
		transition: transform 0.22s ease, background 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
		box-shadow: 0 2px 12px rgba(0,0,0,0.18);
	}

	.admin-card:hover {
		transform: translateY(-4px);
		background: rgba(255, 255, 255, 0.09);
		border-color: rgba(211,217,212,0.45);
		box-shadow: 0 8px 28px rgba(0,0,0,0.28);
	}

	.icon {
		font-size: 2.4rem;
		margin-bottom: 1.1rem;
		display: block;
	}

	h3 {
		margin: 0 0 0.6rem 0;
		font-size: 1.15rem;
		color: var(--color-button);
		font-weight: 700;
	}

	p {
		margin: 0;
		font-size: 0.85rem;
		color: rgba(255,255,255,0.58);
		line-height: 1.5;
	}
</style>
