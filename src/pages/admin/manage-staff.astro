---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Manage Staff | Sahati Gym">
	<section class="admin-container">
		<div class="page-header">
			<div>
				<h1>Manage Staff</h1>
				<p>Add, edit, or remove gym staff accounts.</p>
			</div>
			<button id="add-staff-btn" class="btn primary">+ Add Staff</button>
		</div>

		<div class="card search-card">
			<div class="search-wrapper">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				<input type="text" id="staff-search" placeholder="Search by name or email…" />
			</div>
		</div>

		<div class="card table-card">
			<div class="table-scroll">
				<table>
					<thead>
						<tr>
							<th>Staff Member</th>
							<th>Phone</th>
							<th>Joined</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody id="staff-table-body"></tbody>
				</table>
				<div id="empty-state" class="empty-state hidden">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3;margin-bottom:1rem"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					<p>No staff accounts found.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Staff Modal -->
	<div id="staff-modal" class="modal hidden">
		<div class="modal-content">
			<h2 id="modal-title">Add New Staff</h2>
			<form id="staff-form">
				<input type="hidden" id="staff-id" name="id" />
				<div class="form-group">
					<label for="staff-name">Full Name</label>
					<input type="text" id="staff-name" name="name" placeholder="Jane Smith" required />
				</div>
				<div class="form-group">
					<label for="staff-email">Email Address</label>
					<input type="email" id="staff-email" name="email" placeholder="jane@sahati.gym" required />
				</div>
				<div class="form-group">
					<label for="staff-phone">Phone Number</label>
					<input type="tel" id="staff-phone" name="phone" placeholder="+1 234 567 8900" required />
				</div>
				<div id="password-group" class="form-group">
					<label for="staff-password">Password</label>
					<input type="password" id="staff-password" name="password" placeholder="Min. 6 characters" minlength="6" />
				</div>
				<div class="modal-actions">
					<button type="button" id="cancel-modal" class="btn secondary">Cancel</button>
					<button type="submit" class="btn primary">Save Staff</button>
				</div>
			</form>
		</div>
	</div>

	<div id="toast" class="toast hidden"></div>
</AdminLayout>

<script>
	let staffMembers: any[] = [];
	const tableBody   = document.getElementById('staff-table-body');
	const emptyState  = document.getElementById('empty-state');
	const searchInput = document.getElementById('staff-search') as HTMLInputElement;
	const addBtn      = document.getElementById('add-staff-btn');
	const modal       = document.getElementById('staff-modal');
	const cancelBtn   = document.getElementById('cancel-modal');
	const form        = document.getElementById('staff-form') as HTMLFormElement;
	const pwdGroup    = document.getElementById('password-group');
	const toast       = document.getElementById('toast');

	function showToast(msg: string, type: 'success' | 'error' = 'success') {
		toast!.textContent = msg;
		toast!.className = `toast ${type}`;
		setTimeout(() => { toast!.className = 'toast hidden'; }, 3500);
	}

	function formatDate(date: string) {
		if (!date) return '—';
		return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
	}

	async function loadStaff(query = '') {
		try {
			const res = await fetch(`/api/admin/staff?q=${encodeURIComponent(query)}`);
			staffMembers = await res.json();
			renderTable();
		} catch {
			showToast('Failed to load staff.', 'error');
		}
	}

	function renderTable() {
		if (!staffMembers.length) {
			tableBody!.innerHTML = '';
			emptyState!.classList.remove('hidden');
			return;
		}
		emptyState!.classList.add('hidden');
		tableBody!.innerHTML = staffMembers.map(s => `
			<tr>
				<td>
					<div class="member-cell">
						<strong>${s.name}</strong>
						<span class="sub-text">${s.email}</span>
					</div>
				</td>
				<td>${s.phone || '—'}</td>
				<td class="date-cell">${formatDate(s.created_at)}</td>
				<td>
					<div class="action-group">
						<button class="btn-action btn-edit edit-btn" data-id="${s.id}">Edit</button>
						<button class="btn-action btn-delete delete-btn" data-id="${s.id}">Delete</button>
					</div>
				</td>
			</tr>
		`).join('');

		tableBody!.querySelectorAll('.edit-btn').forEach(btn => {
			btn.addEventListener('click', e => {
				const id = (e.currentTarget as HTMLElement).dataset.id;
				if (id) openEditModal(id);
			});
		});

		tableBody!.querySelectorAll('.delete-btn').forEach(btn => {
			btn.addEventListener('click', e => {
				const id = (e.currentTarget as HTMLElement).dataset.id;
				if (id) handleDelete(id, e.currentTarget as HTMLElement);
			});
		});
	}

	function openEditModal(id: string) {
		const s = staffMembers.find(x => x.id === id);
		if (!s) return;
		(document.getElementById('modal-title') as HTMLElement).textContent = 'Edit Staff';
		(document.getElementById('staff-id')    as HTMLInputElement).value  = s.id;
		(document.getElementById('staff-name')  as HTMLInputElement).value  = s.name;
		(document.getElementById('staff-email') as HTMLInputElement).value  = s.email;
		(document.getElementById('staff-phone') as HTMLInputElement).value  = s.phone || '';
		pwdGroup!.classList.add('hidden');
		modal!.classList.remove('hidden');
	}

	async function handleDelete(id: string, btn: HTMLElement) {
		if (!confirm('Delete this staff member? This action cannot be undone.')) return;
		btn.classList.add('loading');
		try {
			const res = await fetch(`/api/admin/staff?id=${id}`, { method: 'DELETE' });
			if (res.ok) {
				showToast('Staff member deleted.', 'success');
				loadStaff(searchInput.value);
			} else {
				showToast('Delete failed: ' + await res.text(), 'error');
			}
		} finally {
			btn.classList.remove('loading');
		}
	}

	addBtn?.addEventListener('click', () => {
		(document.getElementById('modal-title') as HTMLElement).textContent = 'Add New Staff';
		form.reset();
		(document.getElementById('staff-id') as HTMLInputElement).value = '';
		pwdGroup!.classList.remove('hidden');
		modal!.classList.remove('hidden');
	});

	cancelBtn?.addEventListener('click', () => modal!.classList.add('hidden'));

	form.addEventListener('submit', async e => {
		e.preventDefault();
		const data      = Object.fromEntries(new FormData(form).entries());
		const isEdit    = !!data.id;
		const submitBtn = form.querySelector('button[type="submit"]');
		submitBtn?.classList.add('loading');
		try {
			const res = await fetch('/api/admin/staff', {
				method: isEdit ? 'PUT' : 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(data)
			});
			if (res.ok) {
				modal!.classList.add('hidden');
				showToast(isEdit ? '✓ Staff updated.' : '✓ Staff added.', 'success');
				loadStaff(searchInput.value);
			} else {
				showToast('Operation failed: ' + await res.text(), 'error');
			}
		} finally {
			submitBtn?.classList.remove('loading');
		}
	});

	let debounce: ReturnType<typeof setTimeout>;
	searchInput?.addEventListener('input', e => {
		clearTimeout(debounce);
		debounce = setTimeout(() => loadStaff((e.target as HTMLInputElement).value), 300);
	});

	loadStaff();
</script>

<style>
	.admin-container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1.75rem;
		gap: 1rem;
	}

	.page-header h1 { font-size: 1.75rem; margin-bottom: 0.25rem; }
	.page-header p  { color: var(--color-text-muted); margin: 0; font-size: 0.88rem; }

	/* Search */
	.search-card { padding: 1.1rem 1.4rem; }
	.search-wrapper { position: relative; }
	.search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--color-text-subtle);
		pointer-events: none;
	}
	.search-wrapper input { padding-left: 2.75rem; }

	/* Table */
	.table-card   { padding: 0; overflow: hidden; }
	.table-scroll { overflow-x: auto; }

	.member-cell { display: flex; flex-direction: column; gap: 0.15rem; }
	.sub-text  { font-size: 0.8rem; color: var(--color-text-muted); }
	.date-cell { font-size: 0.85rem; color: var(--color-text-muted); }

	/* Action buttons */
	.action-group {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.btn-action {
		padding: 0.38rem 0.85rem;
		border-radius: var(--radius-sm);
		font-size: 0.8rem;
		font-weight: 600;
		cursor: pointer;
		border: 1px solid transparent;
		transition: background var(--transition), opacity var(--transition);
		position: relative;
	}

	.btn-edit {
		background: rgba(69,123,157,0.2);
		color: #82c2e0;
		border-color: rgba(69,123,157,0.35);
	}
	.btn-edit:hover { background: rgba(69,123,157,0.38); }

	.btn-delete {
		background: rgba(230,57,70,0.15);
		color: #ef9a9a;
		border-color: rgba(230,57,70,0.3);
	}
	.btn-delete:hover { background: rgba(230,57,70,0.3); }

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 3rem 2rem;
		text-align: center;
	}
	.empty-state p { color: var(--color-text-subtle); margin: 0; }

	/* Toast */
	.toast {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		padding: 0.85rem 1.6rem;
		border-radius: var(--radius-md);
		font-weight: 600;
		font-size: 0.88rem;
		z-index: 2000;
		box-shadow: 0 4px 20px rgba(0,0,0,0.4);
		animation: slideUp 0.22s ease;
	}
	.toast.success { background: #2e7d32; color: #fff; }
	.toast.error   { background: #c62828; color: #fff; }
	.toast.hidden  { display: none !important; }

	@keyframes slideUp {
		from { opacity: 0; transform: translateY(10px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 600px) {
		.page-header { flex-direction: column; }
	}
</style>
