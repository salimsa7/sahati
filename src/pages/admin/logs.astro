---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Access Logs | Sahati Gym">
	<section class="admin-container">
		<div class="page-header">
			<div>
				<h1>Access Logs</h1>
				<p>Read-only log of all QR scan attempts by staff.</p>
			</div>
			<button id="refresh-btn" class="btn secondary" title="Refresh logs">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
				Refresh
			</button>
		</div>

		<div class="card search-card">
			<div class="search-wrapper">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				<input type="text" id="log-search" placeholder="Filter by member name or ID…" />
			</div>
		</div>

		<div class="card table-card">
			<div class="table-scroll">
				<table>
					<thead>
						<tr>
							<th>Member</th>
							<th>Member ID</th>
							<th>Timestamp</th>
							<th>Scanned By</th>
							<th>Result</th>
						</tr>
					</thead>
					<tbody id="logs-table-body"></tbody>
				</table>
				<div id="empty-state" class="empty-state hidden">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3;margin-bottom:1rem"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
					<p>No logs found.</p>
				</div>
			</div>
		</div>

		<div class="log-stats" id="log-stats"></div>
	</section>
</AdminLayout>

<script>
	function init() {
		let logs: any[] = [];
		const tableBody   = document.getElementById('logs-table-body');
		const emptyState  = document.getElementById('empty-state');
		const searchInput = document.getElementById('log-search') as HTMLInputElement;
		const refreshBtn  = document.getElementById('refresh-btn');
		const logStats    = document.getElementById('log-stats');

		function formatTs(ts: string) {
			return new Date(ts).toLocaleString('en-US', {
				month: 'short', day: 'numeric', year: 'numeric',
				hour: '2-digit', minute: '2-digit'
			});
		}

		function truncateId(id: string) {
			if (!id) return 'System';
			return id.length > 16 ? id.slice(0, 8) + '…' + id.slice(-4) : id;
		}

		async function loadLogs(query = '') {
			const url = query ? `/api/admin/logs?memberId=${encodeURIComponent(query)}` : '/api/admin/logs';
			const res = await fetch(url);
			logs = await res.json();
			renderTable();
			renderStats();
		}

		function renderTable() {
			if (!tableBody) return;
			if (!logs.length) {
				tableBody.innerHTML = '';
				emptyState?.classList.remove('hidden');
				return;
			}
			emptyState?.classList.add('hidden');
			tableBody.innerHTML = logs.map(l => {
				const granted = l.result === 'granted';
				const badgeClass = granted ? 'badge-success' : 'badge-danger';
				const badgeLabel = granted ? '✓ Granted' : '✗ Denied';
				const memberId   = l.user_id || null;
				return `
					<tr>
						<td>
							<div class="member-cell">
								<strong>${l.users?.name || '<span class="unknown">Unknown</span>'}</strong>
							</div>
						</td>
						<td>
							<code class="id-cell" title="${memberId || 'N/A'}">${memberId ? truncateId(memberId) : '—'}</code>
						</td>
						<td class="ts-cell">${formatTs(l.scanned_at)}</td>
						<td class="staff-cell">${l.staff?.name || '—'}</td>
						<td><span class="badge ${badgeClass}">${badgeLabel}</span></td>
					</tr>
				`;
			}).join('');
		}

		function renderStats() {
			if (!logStats) return;
			const granted = logs.filter(l => l.result === 'granted').length;
			const denied  = logs.filter(l => l.result === 'denied').length;
			if (!logs.length) { logStats.innerHTML = ''; return; }
			logStats.innerHTML = `
				<span class="stat"><span class="stat-label">Total</span><strong>${logs.length}</strong></span>
				<span class="stat granted"><span class="stat-label">Granted</span><strong>${granted}</strong></span>
				<span class="stat denied"><span class="stat-label">Denied</span><strong>${denied}</strong></span>
			`;
		}

		refreshBtn?.addEventListener('click', () => loadLogs(searchInput?.value || ''));

		let debounce: ReturnType<typeof setTimeout>;
		searchInput?.addEventListener('input', e => {
			clearTimeout(debounce);
			debounce = setTimeout(() => loadLogs((e.target as HTMLInputElement).value), 300);
		});

		loadLogs();
	}

	document.addEventListener('astro:page-load', init);
</script>

<style>
	.admin-container {
		max-width: 1080px;
		margin: 0 auto;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1.75rem;
		gap: 1rem;
	}

	.page-header h1 { font-size: 1.75rem; margin-bottom: 0.25rem; }
	.page-header p  { color: var(--color-text-muted); margin: 0; font-size: 0.88rem; }

	/* Search */
	.search-card { padding: 1.1rem 1.4rem; }
	.search-wrapper { position: relative; }
	.search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--color-text-subtle);
		pointer-events: none;
	}
	.search-wrapper input { padding-left: 2.75rem; }

	/* Table */
	.table-card   { padding: 0; overflow: hidden; }
	.table-scroll { overflow-x: auto; }

	.member-cell { display: flex; flex-direction: column; }
	.unknown { color: var(--color-text-subtle); font-style: italic; }

	.id-cell {
		font-family: monospace;
		font-size: 0.78rem;
		color: var(--color-text-muted);
		background: rgba(0,0,0,0.18);
		padding: 0.18rem 0.45rem;
		border-radius: 4px;
		cursor: default;
	}

	.ts-cell  { font-size: 0.84rem; color: var(--color-text-muted); white-space: nowrap; }
	.staff-cell { font-size: 0.87rem; }

	/* Stats bar */
	.log-stats {
		display: flex;
		gap: 1rem;
		justify-content: flex-end;
		margin-top: -0.5rem;
		margin-bottom: 1.5rem;
	}

	.stat {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: 0.35rem 0.85rem;
		border-radius: 20px;
		font-size: 0.82rem;
	}

	.stat-label { color: var(--color-text-muted); }
	.stat.granted strong { color: #81c784; }
	.stat.denied  strong { color: #ef9a9a; }

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 3rem 2rem;
		text-align: center;
	}
	.empty-state p { color: var(--color-text-subtle); margin: 0; }

	@media (max-width: 600px) {
		.page-header { flex-direction: column; }
		.log-stats   { justify-content: flex-start; flex-wrap: wrap; }
	}
</style>
