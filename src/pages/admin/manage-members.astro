---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Manage Members | Sahati Gym">
	<section class="admin-container">
		<div class="page-header">
			<div>
				<h1>Manage Members</h1>
				<p>Add, edit, or remove gym members.</p>
			</div>
			<button id="add-member-btn" class="btn primary">+ Add Member</button>
		</div>

		<div class="card search-card">
			<div class="search-wrapper">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
				<input type="text" id="member-search" placeholder="Search by name, email, or phone…" />
			</div>
		</div>

		<div class="card table-card">
			<div class="table-scroll">
				<table>
					<thead>
						<tr>
							<th>Member</th>
							<th>Phone</th>
							<th>Joined</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody id="members-table-body"></tbody>
				</table>
				<div id="empty-state" class="empty-state hidden">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.3;margin-bottom:1rem"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					<p>No members found.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Member Modal -->
	<div id="member-modal" class="modal hidden">
		<div class="modal-content">
			<h2 id="modal-title">Add New Member</h2>
			<form id="member-form">
				<input type="hidden" id="member-id" name="id" />
				<div class="form-group">
					<label for="member-name">Full Name</label>
					<input type="text" id="member-name" name="name" placeholder="John Doe" required />
				</div>
				<div class="form-group">
					<label for="member-email">Email Address</label>
					<input type="email" id="member-email" name="email" placeholder="john@example.com" required />
				</div>
				<div class="form-group">
					<label for="member-phone">Phone Number</label>
					<input type="tel" id="member-phone" name="phone" placeholder="+1 234 567 8900" required />
				</div>
				<div id="password-group" class="form-group">
					<label for="member-password">Password</label>
					<input type="password" id="member-password" name="password" placeholder="Min. 6 characters" minlength="6" />
				</div>
				<div class="modal-actions">
					<button type="button" id="cancel-modal" class="btn secondary">Cancel</button>
					<button type="submit" class="btn primary">Save Member</button>
				</div>
			</form>
		</div>
	</div>
</AdminLayout>

<script>
	function init() {
		let members: any[] = [];
		const tableBody   = document.getElementById('members-table-body');
		const emptyState  = document.getElementById('empty-state');
		const searchInput = document.getElementById('member-search') as HTMLInputElement;
		const addBtn      = document.getElementById('add-member-btn');
		const modal       = document.getElementById('member-modal');
		const cancelBtn   = document.getElementById('cancel-modal');
		const form        = document.getElementById('member-form') as HTMLFormElement;
		const pwdGroup    = document.getElementById('password-group');

		function formatDate(date: string) {
			if (!date) return '—';
			return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
		}

		async function loadMembers(query = '') {
			try {
				const res = await fetch(`/api/admin/members?q=${encodeURIComponent(query)}`);
				members = await res.json();
				renderTable();
			} catch {
				window.showToast('Failed to load members.', 'error');
			}
		}

		function renderTable() {
			if (!tableBody) return;
			if (!members.length) {
				tableBody.innerHTML = '';
				emptyState?.classList.remove('hidden');
				return;
			}
			emptyState?.classList.add('hidden');
			tableBody.innerHTML = members.map(m => {
				return `
				<tr>
					<td>
						<div class="member-cell">
							<strong>${m.name}</strong>
							<span class="sub-text">${m.email}</span>
						</div>
					</td>
					<td>${m.phone || '—'}</td>
					<td class="date-cell">${formatDate(m.created_at)}</td>
					<td>
						<div class="action-group">
							<button class="btn-action btn-edit edit-btn" data-id="${m.id}">Edit</button>
							<button class="btn-action btn-delete delete-btn" data-id="${m.id}">Delete</button>
						</div>
					</td>
				</tr>
			`;}).join('');

			tableBody.querySelectorAll('.edit-btn').forEach(btn => {
				btn.addEventListener('click', e => {
					const id = (e.currentTarget as HTMLElement).dataset.id;
					if (id) openEditModal(id);
				});
			});

			tableBody.querySelectorAll('.delete-btn').forEach(btn => {
				btn.addEventListener('click', e => {
					const id = (e.currentTarget as HTMLElement).dataset.id;
					if (id) handleDelete(id, e.currentTarget as HTMLElement);
				});
			});
		}

		function openEditModal(id: string) {
			const m = members.find(x => x.id === id);
			if (!m) return;
			(document.getElementById('modal-title') as HTMLElement).textContent = 'Edit Member';
			(document.getElementById('member-id')    as HTMLInputElement).value  = m.id;
			(document.getElementById('member-name')  as HTMLInputElement).value  = m.name;
			(document.getElementById('member-email') as HTMLInputElement).value  = m.email;
			(document.getElementById('member-phone') as HTMLInputElement).value  = m.phone || '';
			pwdGroup?.classList.add('hidden');
			modal?.classList.remove('hidden');
		}

		async function handleDelete(id: string, btn: HTMLElement) {
			const confirmed = await window.confirmAction({
				title: 'Delete Member',
				message: 'Are you sure you want to delete this member? This action cannot be undone.',
				okText: 'Delete',
				type: 'danger'
			});
			
			if (!confirmed) return;
			
			btn.classList.add('loading');
			try {
				const res = await fetch(`/api/admin/members?id=${id}`, { method: 'DELETE' });
				if (res.ok) {
					window.showToast('Member deleted.', 'success');
					loadMembers(searchInput?.value || '');
				} else {
					window.showToast('Delete failed: ' + await res.text(), 'error');
				}
			} finally {
				btn.classList.remove('loading');
			}
		}

		addBtn?.addEventListener('click', () => {
			(document.getElementById('modal-title') as HTMLElement).textContent = 'Add New Member';
			form.reset();
			(document.getElementById('member-id') as HTMLInputElement).value = '';
			pwdGroup?.classList.remove('hidden');
			modal?.classList.remove('hidden');
		});

		cancelBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

		form?.addEventListener('submit', async e => {
			e.preventDefault();
			const data      = Object.fromEntries(new FormData(form).entries());
			const isEdit    = !!data.id;
			const submitBtn = form.querySelector('button[type="submit"]');
			submitBtn?.classList.add('loading');
			try {
				const res = await fetch('/api/admin/members', {
					method: isEdit ? 'PUT' : 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(data)
				});
				if (res.ok) {
					modal?.classList.add('hidden');
					window.showToast(isEdit ? '✓ Member updated.' : '✓ Member added.', 'success');
					loadMembers(searchInput?.value || '');
				} else {
					window.showToast('Operation failed: ' + await res.text(), 'error');
				}
			} finally {
				submitBtn?.classList.remove('loading');
			}
		});

		let debounce: ReturnType<typeof setTimeout>;
		searchInput?.addEventListener('input', e => {
			clearTimeout(debounce);
			debounce = setTimeout(() => loadMembers((e.target as HTMLInputElement).value), 300);
		});

		loadMembers();
	}

	document.addEventListener('astro:page-load', init);
</script>

<style>
	.admin-container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1.75rem;
		gap: 1rem;
	}

	.page-header h1 { font-size: 1.75rem; margin-bottom: 0.25rem; }
	.page-header p  { color: var(--color-text-muted); margin: 0; font-size: 0.88rem; }

	/* Search */
	.search-card { padding: 1.1rem 1.4rem; }
	.search-wrapper { position: relative; }
	.search-icon {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--color-text-subtle);
		pointer-events: none;
	}
	.search-wrapper input { padding-left: 2.75rem; }

	/* Table */
	.table-card  { padding: 0; overflow: hidden; }
	.table-scroll { overflow-x: auto; }

	.member-cell { display: flex; flex-direction: column; gap: 0.15rem; }
	.sub-text { font-size: 0.8rem; color: var(--color-text-muted); }
	.date-cell { font-size: 0.85rem; color: var(--color-text-muted); }

	/* Action buttons */
	.action-group {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.btn-action {
		padding: 0.38rem 0.85rem;
		border-radius: var(--radius-sm);
		font-size: 0.8rem;
		font-weight: 600;
		cursor: pointer;
		border: 1px solid transparent;
		transition: background var(--transition), opacity var(--transition);
		position: relative;
	}

	.btn-edit {
		background: rgba(69,123,157,0.2);
		color: #82c2e0;
		border-color: rgba(69,123,157,0.35);
	}
	.btn-edit:hover { background: rgba(69,123,157,0.38); }

	.btn-delete {
		background: rgba(230,57,70,0.15);
		color: #ef9a9a;
		border-color: rgba(230,57,70,0.3);
	}
	.btn-delete:hover { background: rgba(230,57,70,0.3); }

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 3rem 2rem;
		text-align: center;
	}
	.empty-state p { color: var(--color-text-subtle); margin: 0; }

	@media (max-width: 600px) {
		.page-header { flex-direction: column; }
	}
</style>
