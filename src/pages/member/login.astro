---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Member Login | Sahati Gym">
	<main class="login-container">
		<div class="login-box">
			<div class="logo-container">
				<img src="/logoWithText.svg" alt="Sahati Gym" class="login-logo" />
			</div>
			<h1>Member Login</h1>
			<form id="login-form">
				<input type="hidden" name="role" value="member" />
				
				<div class="form-group">
					<label for="email">Email</label>
					<input type="email" id="email" name="email" required />
				</div>

				<div class="form-group">
					<label for="password">Password</label>
					<input type="password" id="password" name="password" required />
				</div>

			<div id="error-message" class="error-message hidden"></div>

				<button type="submit" class="btn-login">Sign In</button>
			</form>

			<div class="links">
				<a href="/member/create-account">Create account</a>
				<a href="/member/forgot-password">Forgot password?</a>
			</div>
			
			<div class="back-link">
				<a href="/">← Back to Home</a>
			</div>
		</div>
	</main>
</Layout>

<script>
	function init() {
		const form = document.getElementById('login-form') as HTMLFormElement;
		const errorDiv = document.getElementById('error-message');
		const submitBtn = form?.querySelector('button[type="submit"]');

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			
			submitBtn?.classList.add('loading');
			errorDiv!.classList.add('hidden');

			try {
				const response = await fetch('/api/auth/login', {
					method: 'POST',
					body: formData
				});

				if (response.ok) {
					window.location.href = response.url;
				} else {
					const errorText = await response.text();
					errorDiv!.textContent = errorText;
					errorDiv!.classList.remove('hidden');
					window.showToast(errorText, 'error');
				}
			} catch (err) {
				const msg = 'An error occurred. Please try again.';
				errorDiv!.textContent = msg;
				errorDiv!.classList.remove('hidden');
				window.showToast(msg, 'error');
			} finally {
				submitBtn?.classList.remove('loading');
			}
		});
	}

	document.addEventListener('astro:page-load', init);
</script>

<style>
	.login-container {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: 1.5rem;
		background: radial-gradient(ellipse at top, rgba(18,78,102,0.6) 0%, transparent 70%), var(--color-bg);
	}

	.login-box {
		background: linear-gradient(145deg, #16607e, #0f4d64);
		padding: 2.5rem 2.75rem;
		border-radius: 18px;
		width: 100%;
		max-width: 420px;
		border: 1px solid rgba(255,255,255,0.12);
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.45);
	}

	.logo-container {
		text-align: center;
		margin-bottom: 1.75rem;
	}

	.login-logo {
		width: 100%;
		max-width: 180px;
		height: auto;
		object-fit: contain;
	}

	h1 {
		margin: 0 0 1.75rem;
		text-align: center;
		font-size: 1.55rem;
		font-weight: 700;
	}

	.error-message {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(230,57,70,0.12);
		color: #ef9a9a;
		border: 1px solid rgba(230,57,70,0.28);
		padding: 0.75rem 1rem;
		border-radius: var(--radius-sm);
		margin-bottom: 1.1rem;
		font-size: 0.88rem;
		text-align: center;
		justify-content: center;
	}

	.btn-login {
		width: 100%;
		padding: 0.8rem;
		background: var(--color-button);
		color: var(--color-button-text);
		border: none;
		border-radius: var(--radius-sm);
		font-weight: 700;
		font-size: 0.95rem;
		font-family: inherit;
		cursor: pointer;
		margin-top: 0.5rem;
		transition: opacity var(--transition), transform var(--transition);
		position: relative;
	}

	.btn-login:hover { opacity: 0.88; transform: translateY(-1px); }

	/* Reuse global loading spinner for login btn */
	.btn-login.loading { color: transparent !important; pointer-events: none; }
	.btn-login.loading::after {
		content: "";
		position: absolute;
		width: 1.1rem; height: 1.1rem;
		top: 50%; left: 50%;
		margin: -0.55rem 0 0 -0.55rem;
		border: 2px solid rgba(0,0,0,0.15);
		border-top-color: #0d3a4d;
		border-radius: 50%;
		animation: spin 0.6s linear infinite;
	}

	.links {
		display: flex;
		justify-content: space-between;
		margin-top: 1.4rem;
		font-size: 0.85rem;
	}

	.links a {
		color: rgba(211,217,212,0.85);
		text-decoration: none;
		transition: color var(--transition);
	}
	.links a:hover { color: #fff; }

	.back-link {
		margin-top: 1.75rem;
		text-align: center;
		font-size: 0.85rem;
	}

	.back-link a {
		color: rgba(255,255,255,0.5);
		text-decoration: none;
		transition: color var(--transition);
	}
	.back-link a:hover { color: rgba(255,255,255,0.85); }

	@keyframes spin { to { transform: rotate(360deg); } }
</style>
