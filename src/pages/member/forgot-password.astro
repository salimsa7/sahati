---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Forgot Password | Sahati Gym">
	<main class="login-container">
		<div class="login-box">
			<div class="logo-container">
				<img
					src="/logoWithText.svg"
					alt="Sahati Gym"
					class="login-logo"
				/>
			</div>
			<h1>Forgot Password?</h1>
			<div class="message">
				<p>
					If you forgot your password, please contact gym support
					through this number: <br />
					<b><a href="tel:+96896535333">+968 96535333</a></b>
				</p>
			</div>

			<div class="back-link">
				<a href="/member/login">← Back to Login</a>
			</div>
		</div>
	</main>
</Layout>

<style>
	.login-container {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: 1rem;
	}

	.login-box {
		background-color: rgba(255, 255, 255, 0.05);
		padding: 2.5rem;
		border-radius: 12px;
		width: 100%;
		max-width: 400px;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
		text-align: center;
	}

	.logo-container {
		text-align: center;
		margin-bottom: 2rem;
	}

	.login-logo {
		width: 100%;
		max-width: 200px;
		height: auto;
		object-fit: contain;
	}

	h1 {
		margin-top: 0;
		margin-bottom: 2rem;
		font-size: 1.8rem;
	}

	.message {
		line-height: 1.6;
		margin-bottom: 2rem;
		opacity: 0.9;
	}

	.back-link {
		margin-top: 1rem;
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.back-link a {
		text-decoration: none;
	}
</style>
