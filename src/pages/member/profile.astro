---
import MemberLayout from '../../layouts/MemberLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/member/login');

const { data: profile } = await supabase
	.from('users')
	.select('*')
	.eq('id', user.id)
	.single();
---

<MemberLayout title="My Profile | Sahati Gym">
	<section class="profile-container">
		<h1>My Profile</h1>

		<div class="card">
			<h2>Personal Information</h2>
			<div class="form-group">
				<label>Full Name</label>
				<input type="text" value={profile?.name} readonly />
			</div>
			<div class="form-group">
				<label>Email Address</label>
				<input type="email" value={profile?.email} readonly />
			</div>
			<div class="form-group">
				<label>Phone Number</label>
				<input type="tel" value={profile?.phone} readonly />
			</div>
			<div class="info-notice">
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
				To update your name, email, or phone number, please contact gym staff.
			</div>
		</div>

		<div class="card">
			<h2>Change Password</h2>
			<form id="password-form">
				<div class="form-group">
					<label for="new-password">New Password</label>
					<input type="password" id="new-password" name="newPassword" placeholder="Min. 6 characters" required minlength="6" />
				</div>
				<div class="form-group">
					<label for="confirm-password">Confirm New Password</label>
					<input type="password" id="confirm-password" name="confirmNewPassword" placeholder="Repeat new password" required minlength="6" />
				</div>
				<div id="password-message" class="pw-message"></div>
				<button type="submit" class="btn primary" style="width:100%;margin-top:0.5rem;">Update Password</button>
			</form>
		</div>
	</section>
</MemberLayout>

<script>
	import { supabase } from '../../lib/supabase';

	const form = document.getElementById('password-form') as HTMLFormElement;
	const messageDiv = document.getElementById('password-message');

		form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		const newPassword        = formData.get('newPassword') as string;
		const confirmNewPassword = formData.get('confirmNewPassword') as string;
		const submitBtn = form.querySelector('button[type="submit"]');
		const msgEl = document.getElementById('password-message');

		if (newPassword !== confirmNewPassword) {
			msgEl!.textContent = 'Passwords do not match.';
			msgEl!.className = 'pw-message error';
			return;
		}

		submitBtn?.classList.add('loading');
		msgEl!.textContent = '';
		msgEl!.className = 'pw-message';

		const { error } = await supabase.auth.updateUser({ password: newPassword });

		submitBtn?.classList.remove('loading');

		if (error) {
			msgEl!.textContent = error.message;
			msgEl!.className = 'pw-message error';
		} else {
			msgEl!.textContent = '✓ Password updated successfully!';
			msgEl!.className = 'pw-message success';
			form.reset();
		}
	});
</script>

<style>
	.profile-container {
		max-width: 580px;
		margin: 0 auto;
	}

	h1 {
		font-size: 1.75rem;
		margin-bottom: 1.75rem;
	}

	h2 {
		margin-top: 0;
		margin-bottom: 1.4rem;
		font-size: 1.05rem;
		border-bottom: 1px solid rgba(255,255,255,0.08);
		padding-bottom: 0.8rem;
		font-weight: 700;
	}

	input[readonly] {
		opacity: 0.55;
		cursor: not-allowed;
		background: rgba(0,0,0,0.12);
	}

	.info-notice {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		font-size: 0.82rem;
		color: rgba(211,217,212,0.75);
		background: rgba(69,123,157,0.12);
		border: 1px solid rgba(69,123,157,0.25);
		border-radius: var(--radius-sm);
		padding: 0.65rem 0.9rem;
		margin-top: 0.75rem;
		line-height: 1.5;
	}

	.info-notice svg { flex-shrink: 0; margin-top: 0.1rem; }

	.pw-message {
		margin-top: 0.9rem;
		padding: 0.7rem 1rem;
		border-radius: var(--radius-sm);
		font-size: 0.88rem;
		font-weight: 500;
		display: none;
	}

	.pw-message.error {
		display: block;
		background: rgba(230,57,70,0.12);
		color: #ef9a9a;
		border: 1px solid rgba(230,57,70,0.25);
	}

	.pw-message.success {
		display: block;
		background: rgba(76,175,80,0.12);
		color: #81c784;
		border: 1px solid rgba(76,175,80,0.25);
	}
</style>
