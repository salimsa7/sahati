---
import { ClientRouter } from 'astro:transitions';
import Snackbar from '../components/Snackbar.astro';

interface Props {
	title?: string;
}

const { title = 'Sahati Gym' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<ClientRouter />
	</head>
	<body>
		<slot />
		<div id="toast" class="toast hidden"></div>

		<script is:inline>
			window.showToast = (message, type = 'success') => {
				const toast = document.getElementById('toast');
				if (!toast) return;
				toast.textContent = message;
				toast.className = `toast ${type}`;
				setTimeout(() => {
					toast.className = 'toast hidden';
				}, 3500);
			};
		</script>
	</body>
</html>

<style is:global>
	:root {
		--color-bg:            #124e66;
		--color-bg-dark:       #0d3a4d;
		--color-bg-deeper:     #092e3e;
		--color-surface:       rgba(255, 255, 255, 0.06);
		--color-surface-hover: rgba(255, 255, 255, 0.10);
		--color-border:        rgba(255, 255, 255, 0.13);
		--color-border-focus:  rgba(211, 217, 212, 0.55);
		--color-text:          #ffffff;
		--color-text-muted:    rgba(255, 255, 255, 0.68);
		--color-text-subtle:   rgba(255, 255, 255, 0.38);
		--color-button:        #d3d9d4;
		--color-button-text:   #0d3a4d;
		--color-success:       #4caf50;
		--color-danger:        #e63946;
		--color-info:          #457b9d;
		--radius-sm:    6px;
		--radius-md:    10px;
		--radius-lg:    14px;
		--shadow-card:  0 4px 24px rgba(0, 0, 0, 0.28);
		--shadow-modal: 0 8px 48px rgba(0, 0, 0, 0.55);
		--transition:   0.18s ease;
	}

	html, body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background-color: var(--color-bg);
		color: var(--color-text);
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 15px;
		line-height: 1.6;
	}

	* { box-sizing: border-box; }

	p { color: var(--color-text-muted); margin: 0 0 0.5rem; }

	a { color: inherit; }

	h1, h2, h3, h4 { margin: 0 0 1rem; font-weight: 700; line-height: 1.25; }

	/* ── Global inputs & selects ────────────────────────── */
	input, select, textarea {
		width: 100%;
		padding: 0.72rem 1rem;
		border-radius: var(--radius-sm);
		border: 1.5px solid var(--color-border);
		background-color: rgba(0, 0, 0, 0.22);
		color: var(--color-text);
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.93rem;
		transition: border-color var(--transition), box-shadow var(--transition);
		outline: none;
	}

	input::placeholder, textarea::placeholder {
		color: var(--color-text-subtle);
	}

	input:focus, select:focus, textarea:focus {
		border-color: var(--color-border-focus);
		box-shadow: 0 0 0 3px rgba(211, 217, 212, 0.10);
	}

	select option {
		background: #0d3a4d;
		color: #fff;
	}

	/* ── Global buttons ─────────────────────────────────── */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.7rem 1.5rem;
		border-radius: var(--radius-sm);
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.88rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		cursor: pointer;
		border: none;
		transition: opacity var(--transition), transform var(--transition);
		position: relative;
		white-space: nowrap;
	}

	.btn:hover { opacity: 0.87; transform: translateY(-1px); }
	.btn:active { transform: translateY(0); opacity: 1; }

	.btn.primary {
		background-color: var(--color-button);
		color: var(--color-button-text);
	}

	.btn.secondary {
		background-color: transparent;
		color: var(--color-text);
		border: 1.5px solid var(--color-border);
	}
	.btn.secondary:hover { background-color: var(--color-surface-hover); }

	.btn.danger {
		background-color: var(--color-danger);
		color: #fff;
	}

	/* Loading spinner */
	.btn.loading, .logout-btn.loading {
		color: transparent !important;
		pointer-events: none;
	}

	.btn.loading::after, .logout-btn.loading::after {
		content: "";
		position: absolute;
		width: 1.1rem;
		height: 1.1rem;
		top: 50%;
		left: 50%;
		margin: -0.55rem 0 0 -0.55rem;
		border: 2px solid rgba(0, 0, 0, 0.15);
		border-top-color: #0d3a4d;
		border-radius: 50%;
		animation: spin 0.6s linear infinite;
	}

	/* ── Global modal ────────────────────────────────────── */
	.modal {
		position: fixed;
		inset: 0;
		background: rgba(5, 20, 28, 0.78);
		backdrop-filter: blur(5px);
		-webkit-backdrop-filter: blur(5px);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		padding: 1.25rem;
	}

	.modal.hidden { display: none !important; }

	.modal-content {
		width: 100%;
		max-width: 520px;
		max-height: 90vh;
		overflow-y: auto;
		background: linear-gradient(145deg, #175f7b 0%, #0f4a63 100%);
		border: 1px solid rgba(255,255,255,0.14);
		border-radius: var(--radius-lg);
		padding: 2rem 2.25rem;
		box-shadow: var(--shadow-modal);
	}

	.modal-content h2 {
		margin-bottom: 1.5rem;
		font-size: 1.2rem;
	}

	.modal-actions {
		display: flex;
		justify-content: flex-end;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}

	/* ── Global card ─────────────────────────────────────── */
	.card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.75rem;
		margin-bottom: 1.5rem;
		box-shadow: var(--shadow-card);
	}

	/* ── Form group ──────────────────────────────────────── */
	.form-group {
		margin-bottom: 1.1rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.4rem;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	/* ── Global table ────────────────────────────────────── */
	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}

	th {
		text-align: left;
		padding: 0.8rem 1rem;
		border-bottom: 2px solid var(--color-border);
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--color-text-muted);
	}

	td {
		padding: 0.85rem 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
		vertical-align: middle;
	}

	tr:last-child td { border-bottom: none; }
	tr:hover td { background: rgba(255,255,255,0.025); transition: background var(--transition); }

	/* ── Hidden utility ──────────────────────────────────── */
	.hidden { display: none !important; }

	/* ── Status badges ───────────────────────────────────── */
	.badge {
		display: inline-block;
		padding: 0.22rem 0.65rem;
		border-radius: 20px;
		font-size: 0.73rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.badge-success { background: rgba(76,175,80,0.18); color: #81c784; border: 1px solid rgba(76,175,80,0.28); }
	.badge-danger  { background: rgba(230,57,70,0.18);  color: #ef9a9a; border: 1px solid rgba(230,57,70,0.28); }
	.badge-warning { background: rgba(244,162,97,0.18); color: #ffcc80; border: 1px solid rgba(244,162,97,0.28); }

	/* ── Toast / message ─────────────────────────────────── */
	.toast {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		padding: 0.85rem 1.6rem;
		border-radius: var(--radius-md);
		font-weight: 600;
		font-size: 0.88rem;
		z-index: 2000;
		box-shadow: 0 4px 20px rgba(0,0,0,0.4);
		animation: slideUp 0.22s ease;
	}
	.toast.success { background: #2e7d32; color: #fff; }
	.toast.error   { background: #c62828; color: #fff; }

	@keyframes slideUp {
		from { opacity: 0; transform: translateY(10px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}
</style>
