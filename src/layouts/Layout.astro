<style is:global>
	:root {
		--color-bg: #124e66;
		--color-text: #ffffff;
		--color-button: #d3d9d4;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: var(--color-bg);
		color: var(--color-text);
		font-family: sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	/* Global Button Loading State */
	.btn, .logout-btn {
		position: relative;
	}

	.btn.loading, .logout-btn.loading {
		color: transparent !important;
		pointer-events: none;
	}

	.btn.loading::after, .logout-btn.loading::after {
		content: "";
		position: absolute;
		width: 1.2rem;
		height: 1.2rem;
		top: 50%;
		left: 50%;
		margin: -0.6rem 0 0 -0.6rem;
		border: 2px solid rgba(0, 0, 0, 0.1);
		border-top-color: currentColor;
		border-radius: 50%;
		animation: spin 0.6s linear infinite;
	}

	@keyframes spin {
		to { transform: rotate(360deg); }
	}
</style>
